{
  "name": "nightingale-api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc && tsc -p tsconfig.scripts.json && mkdir -p dist/email-templates dist/prompts && cp src/email-templates/*.html dist/email-templates/ && cp src/prompts/*.md dist/prompts/",
    "migrate": "ts-node src/db/runMigrations.ts",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "jest --config jest.config.ts --forceExit",
    "test:watch": "jest --config jest.config.ts --watch --forceExit"
  },
  "dependencies": {
    "@anthropic-ai/bedrock-sdk": "^0.28.1",
    "@anthropic-ai/sdk": "^0.90.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1038.0",
    "@aws-sdk/client-s3": "^3.1035.0",
    "@aws-sdk/s3-request-presigner": "^3.1035.0",
    "@google/genai": "^1.50.1",
    "@sendgrid/eventwebhook": "^8.0.0",
    "@sendgrid/mail": "^8.1.6",
    "@types/pdfkit": "^0.17.6",
    "@types/ws": "^8.18.1",
    "aws-jwt-verify": "^4.0.1",
    "express": "^4.19.2",
    "express-rate-limit": "^8.4.0",
    "file-type": "^16.5.4",
    "he": "^1.2.0",
    "helmet": "^8.1.0",
    "lru-cache": "^11.3.5",
    "multer": "^2.1.1",
    "openai": "^6.34.0",
    "pdfkit": "^0.18.0",
    "pg": "^8.11.5",
    "pino": "^9.2.0",
    "pino-http": "^10.2.0",
    "sharp": "^0.34.5",
    "validator": "^13.15.35",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/he": "^1.2.3",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.14.2",
    "@types/pg": "^8.11.6",
    "@types/supertest": "^7.2.0",
    "@types/validator": "^13.15.10",
    "jest": "^30.3.0",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tslib": "^2.8.1",
    "typescript": "^5.5.2"
  }
}
