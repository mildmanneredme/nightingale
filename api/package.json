{
  "name": "nightingale-api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "jest --config jest.config.ts --forceExit",
    "test:watch": "jest --config jest.config.ts --watch --forceExit"
  },
  "dependencies": {
    "aws-jwt-verify": "^4.0.1",
    "express": "^4.19.2",
    "pg": "^8.11.5",
    "pino": "^9.2.0",
    "pino-http": "^10.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.14.2",
    "@types/pg": "^8.11.6",
    "@types/supertest": "^7.2.0",
    "jest": "^30.3.0",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.2"
  }
}
